# Used by docker-compose.yml only. Copy to `.env` in this same directory
# before running `docker compose up`.

MYSQL_ROOT_PASSWORD=changeme_use_a_real_password
MYSQL_DATABASE=medicore_hms

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run it twice — these two values must be different from each other.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# The origin the frontend is served from (must match the browser's address bar)
CORS_ORIGIN=http://localhost:8080

# All optional — leave blank to run with safe fallbacks (see backend/.env.example
# for what each one enables)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MSG91_AUTHKEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
OPENAI_API_KEY=
GEMINI_API_KEY=
DAILY_API_KEY=
AGORA_APP_ID=
FCM_SERVER_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
