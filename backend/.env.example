# ─── Database ──────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="mysql://root:Havya123@localhost:3306/medicore_hms"

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="8e759b923ed89ad1df373a7c0c06d7aee599eecb9bd744359939a6e017701e8ed45f8553a095734191dfdb3c25dbdda29354086a9b16f2b911b34bc8c38ce9a1"
JWT_REFRESH_SECRET="ab9d6a4e3ebffb62ce4b13ac805001c52a67044f6eb3a7e59eb574cbde2b9e20572d19f88fea138f4404c1160ce3211a0e15b4229ef21afad545be80aeb2166a"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─── Security ───────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10

# ─── Platform bootstrap (one-time) ───────────────────────────────────────────────
# Only consumed by `npm run seed:platform`, which creates the very first
# Developer (platform owner) account. Not read by the running server, so it's
# safe to leave these blank here — set real values only when you actually run
# that script, e.g.:
#   BOOTSTRAP_DEVELOPER_EMAIL=you@company.com BOOTSTRAP_DEVELOPER_PASSWORD=... npm run seed:platform
BOOTSTRAP_DEVELOPER_EMAIL=
BOOTSTRAP_DEVELOPER_PASSWORD=

# Self-serve hospital signup via POST /api/v1/auth/register is OFF by default.
# In production, hospitals are provisioned by a SuperAdmin via
# POST /api/v1/platform/hospitals instead. Flip this to true only if you
# deliberately want public self-signup alongside the platform console.
ALLOW_SELF_SERVE_TENANT_SIGNUP=false

# ─── Optional third-party integrations ───────────────────────────────────────────
# All of these are OPTIONAL. Each feature has a working fallback (console-log
# stub for SMS/WhatsApp, rule-based suggestions for AI, free Jitsi rooms for
# video calls) when its key(s) are not set, so the app runs fully without them.

# WhatsApp / SMS Reminders (module: notification-channels)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MSG91_AUTHKEY=
MSG91_SENDER_ID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# AI Prescription Suggestions (module: ai-prescription) — set ONE of these
OPENAI_API_KEY=
GEMINI_API_KEY=

# Telemedicine / Video Consult (module: telemedicine) — set ONE of these,
# otherwise a free Jitsi room is used automatically
DAILY_API_KEY=
AGORA_APP_ID=

# Patient Mobile App push notifications (module: mobile-app)
FCM_SERVER_KEY=

# Transactional email (password reset, statements, notification-channels, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

