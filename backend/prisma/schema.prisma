  @@unique([tenantId, employeeId, month, year])
  @@index([tenantId])
  @@index([employeeId])
  @@map("statutory_registers")
}


model BookingSlug {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  slug         String   @unique @db.VarChar(100)
  isActive     Boolean  @default(true) @map("is_active")
  allowedDays  Json?    @map("allowed_days")
  slotDuration Int      @default(15) @map("slot_duration")
  startHour    Int      @default(9) @map("start_hour")
  endHour      Int      @default(17) @map("end_hour")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("booking_slugs")
}


enum NotificationChannel {
  SMS
  WhatsApp
  Email
  Push
}

enum NotificationLogStatus {
  Queued
  Sent
  Delivered
  Failed
}

model NotificationTemplate {
  id        BigInt              @id @default(autoincrement())
  tenantId  BigInt              @map("tenant_id")
  name      String              @db.VarChar(150)
  channel   NotificationChannel
  eventType String              @map("event_type") @db.VarChar(100)
  subject   String?             @db.VarChar(255)
  body      String              @db.Text
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  logs   NotificationLog[]

  @@index([tenantId])
  @@map("notification_templates")
}

model NotificationLog {
  id          BigInt                @id @default(autoincrement())
  tenantId    BigInt                @map("tenant_id")
  templateId  BigInt?               @map("template_id")
  channel     NotificationChannel
  recipient   String                @db.VarChar(255)
  subject     String?               @db.VarChar(255)
  body        String                @db.Text
  status      NotificationLogStatus @default(Queued)
  errorMsg    String?               @map("error_msg") @db.Text
  sentAt      DateTime?             @map("sent_at")
  entityType  String?               @map("entity_type") @db.VarChar(50)
  entityId    BigInt?               @map("entity_id")
  createdAt   DateTime              @default(now()) @map("created_at")

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  template NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("notification_logs")
}


model PrescriptionSeal {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  doctorId     BigInt   @map("doctor_id")
  sealText     String   @map("seal_text") @db.VarChar(500)
  registrationNo String? @map("registration_no") @db.VarChar(100)
  signatureUrl String?  @map("signature_url") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([tenantId])
  @@index([doctorId])
  @@map("prescription_seals")
}


enum SterilizationMethod {
  Autoclave
  ETO
  DryHeat
  Plasma
  Chemical
}

enum CssdStatus {
  Dirty
  Washing
  Packing
  Sterilizing
  Sterile
  InUse
  Expired
  Condemned
}

model CssdItem {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  itemCode     String    @unique @map("item_code") @db.VarChar(50)
  name         String    @db.VarChar(255)
  category     String    @db.VarChar(100)
  quantity     Int       @default(1)
  department   String?   @db.VarChar(150)
  status       CssdStatus @default(Dirty)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  packs  CssdPackItem[]

  @@index([tenantId])
  @@index([status])
  @@map("cssd_items")
}

model CssdPack {
  id            BigInt             @id @default(autoincrement())
  tenantId      BigInt             @map("tenant_id")
  packCode      String             @unique @map("pack_code") @db.VarChar(50)
  packName      String             @map("pack_name") @db.VarChar(255)
  status        CssdStatus         @default(Dirty)
  department    String?            @db.VarChar(150)
  preparedBy    BigInt?            @map("prepared_by")
  sterilizedAt  DateTime?          @map("sterilized_at")
  expiresAt     DateTime?          @map("expires_at")
  usedAt        DateTime?          @map("used_at")
  usedFor       String?            @map("used_for") @db.VarChar(255)
  notes         String?            @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  items  CssdPackItem[]
  cycles CssdCycleItem[]

  @@index([tenantId])
  @@index([status])
  @@map("cssd_packs")
}

model CssdPackItem {
  id       BigInt @id @default(autoincrement())
  packId   BigInt @map("pack_id")
  itemId   BigInt @map("item_id")
  quantity Int    @default(1)

  pack CssdPack @relation(fields: [packId], references: [id])
  item CssdItem @relation(fields: [itemId], references: [id])

  @@index([packId])
  @@map("cssd_pack_items")
}

model CssdCycle {
  id                  BigInt              @id @default(autoincrement())
  tenantId            BigInt              @map("tenant_id")
  cycleNumber         String              @unique @map("cycle_number") @db.VarChar(50)
  autoclaveName       String?             @map("autoclave_name") @db.VarChar(100)
  sterilizationMethod SterilizationMethod @map("sterilization_method")
  startedAt           DateTime            @map("started_at")
  completedAt         DateTime?           @map("completed_at")
  temperature         Decimal?            @db.Decimal(6, 2)
  pressure            Decimal?            @db.Decimal(6, 2)
  duration            Int?
  batchIndicator      String?             @map("batch_indicator") @db.VarChar(50)
  operatorId          BigInt?             @map("operator_id")
  isSuccessful        Boolean             @default(true) @map("is_successful")
  failureReason       String?             @map("failure_reason") @db.Text
  notes               String?             @db.Text
  createdAt           DateTime            @default(now()) @map("created_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  items  CssdCycleItem[]

  @@index([tenantId])
  @@map("cssd_cycles")
}

model CssdCycleItem {
  id      BigInt @id @default(autoincrement())
  cycleId BigInt @map("cycle_id")
  packId  BigInt @map("pack_id")

  cycle CssdCycle @relation(fields: [cycleId], references: [id])
  pack  CssdPack  @relation(fields: [packId], references: [id])

  @@index([cycleId])
  @@map("cssd_cycle_items")
}

// UNIFIED ENCOUNTER TABLE — connects OPD / IPD / Emergency

enum EncounterType {
  OPD
  IPD
  Emergency
  Teleconsultation
}

enum EncounterStatus {
  Active
  Completed
  Cancelled
  Transferred
}

model Encounter {
  id            BigInt          @id @default(autoincrement())
  tenantId      BigInt          @map("tenant_id")
  patientId     BigInt          @map("patient_id")
  doctorId      BigInt?         @map("doctor_id")
  type          EncounterType
  referenceType String          @map("reference_type") @db.VarChar(50)
  referenceId   BigInt          @map("reference_id")
  startTime     DateTime        @map("start_time")
  endTime       DateTime?       @map("end_time")
  status        EncounterStatus @default(Active)
  chiefComplaint String?        @map("chief_complaint") @db.Text
  diagnosis     String?         @db.Text
  notes         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  patient Patient  @relation(fields: [patientId], references: [id])
  doctor  Doctor?  @relation(fields: [doctorId], references: [id])
  orders  ClinicalOrder[]

  @@index([tenantId])
  @@index([patientId])
  @@index([type, status])
  @@map("encounters")
}

// SERVICE MASTER — centralized billing item catalog

enum ServiceType {
  Consultation
  Procedure
  Lab
  Radiology
  Pharmacy
  Room
  Nursing
  Other
}

model ServiceMaster {
  id            BigInt      @id @default(autoincrement())
  tenantId      BigInt      @map("tenant_id")
  serviceCode   String      @map("service_code") @db.VarChar(50)
  name          String      @db.VarChar(255)
  serviceType   ServiceType @map("service_type")
  departmentId  BigInt?     @map("department_id")
  standardPrice Decimal     @map("standard_price") @db.Decimal(12, 2)
  taxPercent    Decimal     @default(0) @map("tax_percent") @db.Decimal(5, 2)
  isActive      Boolean     @default(true) @map("is_active")
  description   String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  orders ClinicalOrder[]

  @@unique([tenantId, serviceCode])
  @@index([tenantId])
  @@index([serviceType])
  @@map("service_masters")
}

// CLINICAL ORDERS — unified lab/radiology/pharmacy/procedure orders

enum OrderType {
  Lab
  Radiology
  Pharmacy
  Procedure
  Diet
  Nursing
}

enum OrderStatus {
  Pending
  InProgress
  Completed
  Cancelled
  OnHold
}

enum OrderPriority {
  Routine
  Urgent
  Stat
  Emergency
}

model ClinicalOrder {
  id            BigInt        @id @default(autoincrement())
  tenantId      BigInt        @map("tenant_id")
  encounterId   BigInt?       @map("encounter_id")
  patientId     BigInt        @map("patient_id")
  doctorId      BigInt        @map("doctor_id")
  orderType     OrderType     @map("order_type")
  serviceId     BigInt?       @map("service_id")
  referenceType String?       @map("reference_type") @db.VarChar(50)
  referenceId   BigInt?       @map("reference_id")
  status        OrderStatus   @default(Pending)
  priority      OrderPriority @default(Routine)
  notes         String?       @db.Text
  orderedAt     DateTime      @default(now()) @map("ordered_at")
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  encounter Encounter?     @relation(fields: [encounterId], references: [id])
  patient   Patient        @relation(fields: [patientId], references: [id])
  doctor    Doctor         @relation(fields: [doctorId], references: [id])
  service   ServiceMaster? @relation(fields: [serviceId], references: [id])

  @@index([tenantId])
  @@index([patientId])
  @@index([encounterId])
  @@index([status])
  @@map("clinical_orders")
}

// PAYMENT SPLIT — multi-method payments per bill

model PaymentSplit {
  id              BigInt        @id @default(autoincrement())
  tenantId        BigInt        @map("tenant_id")
  billId          BigInt        @map("bill_id")
  paymentId       BigInt?       @map("payment_id")
  method          String        @db.VarChar(50)
  amount          Decimal       @db.Decimal(12, 2)
  reference       String?       @db.VarChar(255)
  settledAt       DateTime?     @map("settled_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  bill   Bill   @relation(fields: [billId], references: [id])

  @@index([tenantId])
  @@index([billId])
  @@map("payment_splits")
}

// BED STATUS HISTORY — live bed tracking

model BedStatusHistory {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt   @map("tenant_id")
  bedId       BigInt   @map("bed_id")
  patientId   BigInt?  @map("patient_id")
  admissionId BigInt?  @map("admission_id")
  fromStatus  String   @map("from_status") @db.VarChar(50)
  toStatus    String   @map("to_status") @db.VarChar(50)
  changedBy   BigInt?  @map("changed_by")
  changedAt   DateTime @default(now()) @map("changed_at")
  notes       String?  @db.Text

  tenant Tenant @relation(fields: [tenantId], references: [id])
  bed    Bed    @relation(fields: [bedId], references: [id])

  @@index([tenantId])
  @@index([bedId])
  @@map("bed_status_history")
}

// ENHANCED AUDIT LOG EXTENDED — compliance-grade

model AuditLogExtended {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  userId       BigInt?  @map("user_id")
  userName     String?  @map("user_name") @db.VarChar(200)
  role         String?  @db.VarChar(100)
  module       String   @db.VarChar(100)
  action       String   @db.VarChar(100)
  entityType   String   @map("entity_type") @db.VarChar(100)
  entityId     String   @map("entity_id") @db.VarChar(100)
  description  String?  @db.Text
  oldValue     Json?    @map("old_value")
  newValue     Json?    @map("new_value")
  ipAddress    String?  @map("ip_address") @db.VarChar(100)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  sessionId    String?  @map("session_id") @db.VarChar(200)
  severity     String   @default("INFO") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([module, action])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs_extended")
}
