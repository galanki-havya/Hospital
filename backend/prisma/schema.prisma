// MediCore HMS — Prisma Schema
// Multi-tenant Hospital Management System
//
// Scope note: the source DDL (db.txt) defines ~120 tables across 20+ modules.
// This schema implements 47 of those tables across 13 modules end-to-end
// (Platform/Auth, Departments & Doctors, Patients, Appointments, Visits/EMR,
// IPD, Pharmacy, Lab, Radiology, Billing, HR, Notifications, Audit Logs).
// Every table here matches the column names/types/relations in db.txt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// PLATFORM / MULTI-TENANCY / AUTH

enum TenantType {
  Clinic
  MultiSpeciality
  SuperSpeciality
}

enum ActiveStatus {
  Active
  Inactive
}

// Platform-level operators. Completely separate identity space from
// tenant Users/Roles below — a PlatformUser has no row in `users` and
// cannot be looked up by the tenant `authenticate` middleware, and a
// tenant User has no row here and cannot pass `authenticatePlatform`.
// This is what makes hospital-data isolation from Developer/SuperAdmin
// structural rather than just a permission flag.
enum PlatformRole {
  Developer
  SuperAdmin
}

model Tenant {
  id        BigInt     @id @default(autoincrement())
  name      String     @db.VarChar(255)
  code      String     @unique @db.VarChar(50)
  type      TenantType
  domain    String?    @db.VarChar(255)
  logoUrl   String?    @map("logo_url") @db.Text
  phone     String?    @db.VarChar(20)
  email     String?    @db.VarChar(150)
  address   String?    @db.Text
  status    ActiveStatus @default(Active)
  suspendedReason      String?    @map("suspended_reason") @db.Text
  plan                 String?    @default("Trial") @db.VarChar(50)
  planExpiresAt        DateTime?  @map("plan_expires_at")
  officeLat            Decimal?   @map("office_lat") @db.Decimal(10, 7)
  officeLng            Decimal?   @map("office_lng") @db.Decimal(10, 7)
  geofenceRadiusMeters Int?       @map("geofence_radius_meters")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  // Which platform operator (SuperAdmin/Developer) provisioned this hospital.
  // Never used to grant that operator any access back into tenant data —
  // it's metadata only, read by platform-side reporting.
  createdByPlatformUserId BigInt?      @map("created_by_platform_user_id")
  createdByPlatformUser   PlatformUser? @relation(fields: [createdByPlatformUserId], references: [id])

  roles            Role[]
  tenantUsers      TenantUser[]
  departments      Department[]
  doctors          Doctor[]
  patients         Patient[]
  appointments     Appointment[]
  visits           Visit[]
  wards            Ward[]
  rooms            Room[]
  beds             Bed[]
  admissions       Admission[]
  suppliers        Supplier[]
  medicineCategories MedicineCategory[]
  medicines        Medicine[]
  pharmacySales    PharmacySale[]
  labCategories    LabCategory[]
  labTests         LabTest[]
  labOrders        LabOrder[]
  radiologyServices RadiologyService[]
  radiologyOrders  RadiologyOrder[]
  billingCategories BillingCategory[]
  bills            Bill[]
  payments         Payment[]
  designations     Designation[]
  employees        Employee[]
  leaveTypes       LeaveType[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  prescriptions    Prescription[]
  medicalRecords   MedicalRecord[]
  emergencyCases   EmergencyCase[]
  otRooms          OTRoom[]
  otSchedules      OTSchedule[]
  insurancePayers  InsurancePayer[]
  insuranceClaims  InsuranceClaim[]
  bloodDonors      BloodDonor[]
  bloodUnits       BloodUnit[]
  dietPlans        DietPlan[]
  dietAssignments  DietAssignment[]
  inventoryCategories InventoryCategory[]
  inventoryItems   InventoryItem[]
  purchaseOrders   PurchaseOrder[]
  stockTransactions StockTransaction[]
  shiftTemplates   ShiftTemplate[]
  shiftAssignments ShiftAssignment[]
  doctorRevenueRules DoctorRevenueRule[]
  doctorRevenueEntries DoctorRevenueEntry[]
  incentiveRules   IncentiveRule[]
  incentiveEntries IncentiveEntry[]
  employeeLoans    EmployeeLoan[]
  jobPostings      JobPosting[]
  jobApplications  JobApplication[]
  documentVault    DocumentVault[]
  letterTemplates  LetterTemplate[]
  letterIssuances  LetterIssuance[]
  performanceReviews PerformanceReview[]
  overtimeRecords   OvertimeRecord[]
  statutoryRegisters StatutoryRegister[]
  ambulances       Ambulance[]
  ambulanceCalls   AmbulanceCall[]
  visitors         Visitor[]
  complaints       Complaint[]
  mortuaryRecords  MortuaryRecord[]
  qrCheckIns       QRCheckIn[]
  salaryStructures  SalaryStructure[]
  salaryAssignments SalaryAssignment[]
  bookingSlugs      BookingSlug[]
  notificationTemplates NotificationTemplate[]
  notificationLogs  NotificationLog[]
  prescriptionSeals PrescriptionSeal[]
  cssdItems         CssdItem[]
  cssdPacks         CssdPack[]
  cssdCycles        CssdCycle[]
  encounters        Encounter[]
  serviceMasters    ServiceMaster[]
  clinicalOrders    ClinicalOrder[]
  paymentSplits     PaymentSplit[]
  bedStatusHistory  BedStatusHistory[]
  auditLogsExtended AuditLogExtended[]
  employeeDocuments EmployeeDocument[]
  biometricDevices  BiometricDevice[]
  biometricLogs     BiometricLog[]
  mobileAppConfig   MobileAppConfig?
  mobileAppRegistrations MobileAppRegistration[]
  voiceNotes        VoiceNote[]

  @@map("tenants")
}

// PLATFORM ADMIN LAYER (Developer + SuperAdmin)
//
// These accounts live OUTSIDE every tenant. They are never inserted into
// `tenant_users`, are never assigned a tenant `Role`, and their JWTs never
// carry a tenantId claim. Every platform route/service in this codebase
// only ever touches the `Tenant` table and aggregate counts of it — never
// Patient/Visit/Prescription/etc. So a SuperAdmin genuinely cannot see any
// hospital's clinical or operational data, by construction, not by policy.
//
// Developer: bootstraps the platform, creates/manages SuperAdmin accounts,
//            full platform settings.
// SuperAdmin: creates hospitals (tenants), sees only how many/which
//             hospitals exist + basic status, activates/suspends them,
//             manages subscription plan, resets a Hospital Admin's
//             password. Cannot view patients, staff rosters, records, etc.

model PlatformUser {
  id            BigInt       @id @default(autoincrement())
  email         String       @unique @db.VarChar(150)
  passwordHash  String       @map("password_hash") @db.Text
  firstName     String?      @map("first_name") @db.VarChar(100)
  lastName      String?      @map("last_name") @db.VarChar(100)
  role          PlatformRole
  isActive      Boolean      @default(true) @map("is_active")
  lastLogin     DateTime?    @map("last_login")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  createdByPlatformUserId BigInt?       @map("created_by_platform_user_id")
  createdBy               PlatformUser?  @relation("PlatformUserCreatedBy", fields: [createdByPlatformUserId], references: [id])
  createdPlatformUsers    PlatformUser[] @relation("PlatformUserCreatedBy")

  createdTenants Tenant[]
  sessions       PlatformUserSession[]
  auditLogs      PlatformAuditLog[]

  @@index([role])
  @@map("platform_users")
}

model PlatformUserSession {
  id             BigInt   @id @default(autoincrement())
  platformUserId BigInt   @map("platform_user_id")
  refreshToken   String   @db.Text
  deviceName     String?  @map("device_name")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  revokedAt      DateTime? @map("revoked_at")

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id])

  @@index([platformUserId])
  @@map("platform_user_sessions")
}

model PlatformAuditLog {
  id             BigInt   @id @default(autoincrement())
  platformUserId BigInt?  @map("platform_user_id")
  actionType     String   @map("action_type") @db.VarChar(100)
  targetTenantId BigInt?  @map("target_tenant_id")
  metadata       Json?
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id])

  @@index([platformUserId])
  @@index([targetTenantId])
  @@map("platform_audit_logs")
}

model User {
  id            BigInt    @id @default(autoincrement())
  email         String    @unique @db.VarChar(150)
  passwordHash  String    @map("password_hash") @db.Text
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  profilePhoto  String?   @map("profile_photo") @db.Text
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenantUsers   TenantUser[]
  doctor        Doctor?
  employee      Employee?
  sessions      UserSession[]
  auditLogs     AuditLog[]
  notifications Notification[]
  uploadedFiles File[]
  voiceNotes    VoiceNote[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt   @map("tenant_id")
  name        String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantUsers TenantUser[]
  permissions RolePermission[]

  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id         BigInt   @id @default(autoincrement())
  name       String   @unique @db.VarChar(150)
  moduleName String?  @map("module_name") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model TenantUser {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @map("tenant_id")
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

model UserSession {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  refreshToken String?   @map("refresh_token") @db.Text
  deviceName   String?   @map("device_name") @db.VarChar(255)
  ipAddress    String?   @map("ip_address") @db.VarChar(100)
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_sessions")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt   @map("tenant_id")
  userId      BigInt?  @map("user_id")
  moduleName  String?  @map("module_name") @db.VarChar(150)
  actionType  String?  @map("action_type") @db.VarChar(100)
  entityName  String?  @map("entity_name") @db.VarChar(150)
  entityId    BigInt?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entityName, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// DEPARTMENTS & DOCTORS

model Department {
  id          BigInt       @id @default(autoincrement())
  tenantId    BigInt       @map("tenant_id")
  name        String       @db.VarChar(150)
  description String?      @db.Text
  status      ActiveStatus @default(Active)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  doctors   Doctor[]
  employees Employee[]

  @@index([tenantId])
  @@map("departments")
}

model Doctor {
  id               BigInt       @id @default(autoincrement())
  tenantId         BigInt       @map("tenant_id")
  userId           BigInt       @unique @map("user_id")
  departmentId     BigInt?      @map("department_id")
  employeeCode     String?      @map("employee_code") @db.VarChar(50)
  specialization   String?      @db.VarChar(150)
  qualification    String?      @db.VarChar(255)
  consultationFee  Decimal?     @map("consultation_fee") @db.Decimal(10, 2)
  licenseNumber    String?      @map("license_number") @db.VarChar(100)
  experienceYears  Int?         @map("experience_years")
  status           ActiveStatus @default(Active)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  user       User              @relation(fields: [userId], references: [id])
  department Department?       @relation(fields: [departmentId], references: [id])
  schedules  DoctorSchedule[]
  appointments Appointment[]
  visits     Visit[]
  admissions Admission[]
  clinicalNotes ClinicalNote[]
  prescriptions Prescription[]
  labOrders  LabOrder[]
  radiologyOrders RadiologyOrder[]
  emergencyCases EmergencyCase[]
  otSchedules    OTSchedule[]
  revenueRules   DoctorRevenueRule[]
  revenueEntries DoctorRevenueEntry[]
  prescriptionSeals PrescriptionSeal[]
  encounters     Encounter[]
  clinicalOrders ClinicalOrder[]
  @@index([userId])
  @@index([departmentId])
  @@map("doctors")
}

model DoctorSchedule {
  id          BigInt   @id @default(autoincrement())
  tenantId    BigInt   @map("tenant_id")
  doctorId    BigInt   @map("doctor_id")
  dayOfWeek   Int      @map("day_of_week") // 0=Sunday..6=Saturday
  startTime   DateTime @map("start_time") @db.Time()
  endTime     DateTime @map("end_time") @db.Time()
  maxPatients Int?     @map("max_patients")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@map("doctor_schedules")
}

// PATIENTS

enum Gender {
  Male
  Female
  Other
}

model Patient {
  id                    BigInt       @id @default(autoincrement())
  tenantId              BigInt       @map("tenant_id")
  uhid                  String       @unique @db.VarChar(50)
  firstName             String?      @map("first_name") @db.VarChar(100)
  lastName              String?      @map("last_name") @db.VarChar(100)
  gender                Gender?
  dob                   DateTime?    @db.Date
  bloodGroup            String?      @map("blood_group") @db.VarChar(10)
  maritalStatus         String?      @map("marital_status") @db.VarChar(50)
  nationality            String?      @db.VarChar(100)
  occupation            String?      @db.VarChar(150)
  phone                 String?      @db.VarChar(20)
  email                 String?      @db.VarChar(150)
  address               String?      @db.Text
  city                  String?      @db.VarChar(100)
  state                 String?      @db.VarChar(100)
  country               String?      @db.VarChar(100)
  emergencyContactName  String?      @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactPhone String?      @map("emergency_contact_phone") @db.VarChar(20)
  status                ActiveStatus @default(Active)
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  deletedAt             DateTime?    @map("deleted_at")

  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  allergies       PatientAllergy[]
  medicalHistory  PatientMedicalHistory[]
  appointments    Appointment[]
  visits          Visit[]
  admissions      Admission[]
  prescriptions   Prescription[]
  pharmacySales   PharmacySale[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]
  bills           Bill[]
  emergencyCases  EmergencyCase[]
  otSchedules     OTSchedule[]
  insuranceClaims InsuranceClaim[]
  dietAssignments DietAssignment[]
  visitors        Visitor[]
  complaints      Complaint[]
  mortuaryRecords MortuaryRecord[]
  encounters      Encounter[]
  clinicalOrders  ClinicalOrder[]
  mobileAppRegistrations MobileAppRegistration[]
  voiceNotes      VoiceNote[]

  @@index([tenantId])
  @@index([uhid])
  @@index([phone])
  @@map("patients")
}

model PatientAllergy {
  id           BigInt    @id @default(autoincrement())
  patientId    BigInt    @map("patient_id")
  allergyName  String?   @map("allergy_name") @db.VarChar(255)
  severity     String?   @db.VarChar(100)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_allergies")
}

model PatientMedicalHistory {
  id            BigInt   @id @default(autoincrement())
  patientId     BigInt   @map("patient_id")
  conditionName String?  @map("condition_name") @db.VarChar(255)
  diagnosisDate DateTime? @map("diagnosis_date") @db.Date
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("patient_medical_history")
}

// APPOINTMENTS, VISITS, EMR

enum AppointmentStatus {
  Scheduled
  CheckedIn
  Completed
  Cancelled
  NoShow
}

model Appointment {
  id               BigInt            @id @default(autoincrement())
  tenantId         BigInt            @map("tenant_id")
  patientId        BigInt            @map("patient_id")
  doctorId         BigInt            @map("doctor_id")
  appointmentTime  DateTime          @map("appointment_time")
  tokenNumber      Int?              @map("token_number")
  status           AppointmentStatus @default(Scheduled)
  reason           String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  deletedAt        DateTime?         @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  visit   Visit?

  @@index([tenantId])
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentTime])
  @@index([status])
  @@map("appointments")
}

enum VisitType {
  OPD
  IPD
  Emergency
}

model Visit {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  patientId     BigInt    @map("patient_id")
  doctorId      BigInt    @map("doctor_id")
  appointmentId BigInt?   @unique @map("appointment_id")
  visitType     VisitType @map("visit_type")
  status        String?   @db.VarChar(50)
  visitDate     DateTime  @default(now()) @map("visit_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  patient       Patient         @relation(fields: [patientId], references: [id])
  doctor        Doctor          @relation(fields: [doctorId], references: [id])
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  vitals        Vitals[]
  medicalRecord MedicalRecord?
  clinicalNotes ClinicalNote[]
  prescriptions Prescription[]
  admission     Admission?
  labOrders     LabOrder[]
  radiologyOrders RadiologyOrder[]

  @@index([tenantId])
  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@map("visits")
}

model Vitals {
  id                BigInt   @id @default(autoincrement())
  visitId           BigInt   @map("visit_id")
  temperature       Decimal? @db.Decimal(5, 2)
  pulseRate         Int?     @map("pulse_rate")
  respiratoryRate   Int?     @map("respiratory_rate")
  bloodPressure     String?  @map("blood_pressure") @db.VarChar(50)
  oxygenSaturation  Decimal? @map("oxygen_saturation") @db.Decimal(5, 2)
  height            Decimal? @db.Decimal(5, 2)
  weight            Decimal? @db.Decimal(5, 2)
  bmi               Decimal? @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  visit Visit @relation(fields: [visitId], references: [id])

  @@index([visitId])
  @@map("vitals")
}

model MedicalRecord {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  visitId       BigInt    @unique @map("visit_id")
  diagnosis     String?   @db.Text
  treatmentPlan String?   @map("treatment_plan") @db.Text
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  visit  Visit  @relation(fields: [visitId], references: [id])

  @@index([tenantId])
  @@map("medical_records")
}

model ClinicalNote {
  id        BigInt   @id @default(autoincrement())
  visitId   BigInt   @map("visit_id")
  doctorId  BigInt   @map("doctor_id")
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  visit  Visit  @relation(fields: [visitId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([visitId])
  @@index([doctorId])
  @@map("clinical_notes")
}

model Prescription {
  id                BigInt    @id @default(autoincrement())
  tenantId          BigInt    @map("tenant_id")
  visitId           BigInt    @map("visit_id")
  patientId         BigInt    @map("patient_id")
  doctorId          BigInt    @map("doctor_id")
  prescriptionDate  DateTime  @default(now()) @map("prescription_date")
  instructions      String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  visit   Visit               @relation(fields: [visitId], references: [id])
  doctor  Doctor              @relation(fields: [doctorId], references: [id])
  patient Patient             @relation(fields: [patientId], references: [id])
  items   PrescriptionItem[]
  pharmacySales PharmacySale[]

  @@index([tenantId])
  @@index([visitId])
  @@index([doctorId])
  @@index([patientId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id              BigInt   @id @default(autoincrement())
  prescriptionId  BigInt   @map("prescription_id")
  medicineId      BigInt?  @map("medicine_id")
  medicineName    String?  @map("medicine_name") @db.VarChar(255)
  dosage          String?  @db.VarChar(100)
  frequency       String?  @db.VarChar(100)
  durationDays    Int?     @map("duration_days")
  instructions    String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  medicine     Medicine?    @relation(fields: [medicineId], references: [id])

  @@index([prescriptionId])
  @@index([medicineId])
  @@map("prescription_items")
}

// IPD — WARDS / ROOMS / BEDS / ADMISSIONS

enum WardType {
  General
  SemiPrivate
  Private
  ICU
  NICU
  PICU
  CCU
}

model Ward {
