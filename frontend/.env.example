# Only needed in PRODUCTION when the frontend is served from a different
# origin than the API (e.g. frontend on Vercel/Netlify/S3, API on its own
# domain). In local development, leave this unset — Vite's dev-server proxy
# (see vite.config.js) forwards /api requests to http://localhost:5000 for you.
#
# Must be an absolute URL including /api/v1, e.g.:
# VITE_API_URL=https://api.yourdomain.com/api/v1
VITE_API_URL=
